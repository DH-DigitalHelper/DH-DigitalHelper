# To distribute the raw source alongside the processed data, delete the next line.
data/raw/
data/models/

# SQLite database + WAL/SHM sidecar files (all state lives here; not committed).
data/*.sqlite3
data/*.sqlite3-wal
data/*.sqlite3-shm

# Agent/tooling scratch: SDD task briefs, reports, and review diffs.
.superpowers/

# Claude Code local project config (settings, etc.) — kept locally, not committed.
.claude/

# graphify knowledge graph + cache: regenerated locally via `graphify update .`.
graphify-out/

